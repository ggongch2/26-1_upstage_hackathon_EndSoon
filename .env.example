# Single key:
#   UPSTAGE_API_KEY=up_xxx...
# Multiple keys (round-robin per request) — comma or newline separated:
#   UPSTAGE_API_KEY=up_xxx...,up_yyy...,up_zzz...
UPSTAGE_API_KEY=up_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

UPSTAGE_BASE_URL=https://api.upstage.ai/v1
SOLAR_MODEL=solar-pro2
DOCUMENT_PARSE_MODEL=document-parse

OUTPUT_DIR=./output
WORK_DIR=./work

# Set to true to bypass Upstage API entirely (uses built-in fake document).
# Useful for offline UI/dev work before the API key is available.
MOCK_MODE=false

# Cap on pipelines running at the same time. Extra uploads wait in the
# 'queued' stage. Tune up if you have more keys / higher rate limits.
MAX_CONCURRENT_JOBS=2

# Parallelism for per-element translation. Higher = faster but heavier on Upstage rate limits.
# Default 5 is a safe middle ground; bump to 8-10 if your account has higher quotas.
TRANSLATE_WORKERS=5

# Solar HTTP read timeout in seconds. Bump if you see ReadTimeout on slow chunks.
SOLAR_TIMEOUT=300
